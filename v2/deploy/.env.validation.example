FUNNEL_V2_HOSTNAME=localhost
ACME_EMAIL=owner@example.com

POSTGRES_DB=funnel_v2
POSTGRES_USER=funnel_v2
POSTGRES_PASSWORD=change-me

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-too

FUNNEL_V2_BACKEND_MODE=postgres_verify
FUNNEL_V2_WEB_REQUIRE_AUTH=1
FUNNEL_V2_SESSION_SECURE=0
FUNNEL_V2_API_HOST=0.0.0.0
FUNNEL_V2_API_PORT=8211
FUNNEL_V2_WEB_ORIGIN=http://localhost
FUNNEL_V2_POSTGRES_URL=postgresql+psycopg://funnel_v2:change-me@postgres:5432/funnel_v2
FUNNEL_V2_STORAGE_MODE=s3_compatible
FUNNEL_V2_STORAGE_BUCKET=funnel-v2-validation
FUNNEL_V2_STORAGE_ENDPOINT_URL=http://minio:9000
FUNNEL_V2_STORAGE_REGION=us-east-1
FUNNEL_V2_STORAGE_ACCESS_KEY_ID=minioadmin
FUNNEL_V2_STORAGE_SECRET_ACCESS_KEY=change-me-too
FUNNEL_V2_STORAGE_PREFIX=stock-picking-funnel-v2-validation
FUNNEL_V2_OWNER_EMAIL=owner@example.com
FUNNEL_V2_OWNER_PASSWORD=change-me-owner
FUNNEL_V2_OWNER_NAME=Owner
FUNNEL_V2_BACKUP_ROOT=/app/v2/contracts/hosted-backups
